    {
      "name": "Events - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Node.js Meetup\",\n  \"description\": \"Community event for Node.js developers\",\n  \"date\": \"2026-06-20T10:00:00.000Z\",\n  \"location\": \"Cairo\",\n  \"capacity\": 50,\n  \"category\": \"{{categoryId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/events",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "events"
          ]
        }
      }
    },
    {
      "name": "Events - List with Pagination/Filter",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/events?page=1&limit=10&category={{categoryId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "events"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "category",
              "value": "{{categoryId}}"
            }
          ]
        }
      }
    },
    {
      "name": "Events - Get By Id",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/events/{{eventId}}",
